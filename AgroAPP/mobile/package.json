{
  "name": "agroapp-mobile",
  "version": "1.0.0",
  "private": true,
  "description": "Shell nativa AgroApp (Android / iOS) — carica l'app Streamlit pubblicata",
  "scripts": {
    "config:url": "node scripts/set-server-url.js",
    "cap:sync": "npx cap sync",
    "android": "npx cap open android",
    "ios": "npx cap open ios",
    "build:android": "npx cap sync android && cd android && ./gradlew assembleDebug"
  },
  "dependencies": {
    "@capacitor/android": "^7.0.0",
    "@capacitor/core": "^7.0.0",
    "@capacitor/ios": "^7.0.0",
    "@capacitor/splash-screen": "^7.0.0",
    "@capacitor/status-bar": "^7.0.0"
  },
  "devDependencies": {
    "@capacitor/cli": "^7.0.0",
    "typescript": "^5.7.0"
  },
  "capacitor": {
    "platforms": [
      "android",
      "ios"
    ]
  }
}
